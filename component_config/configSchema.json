{
  "type": "object",
  "title": "Sage Intacct Extractor Configuration",
  "required": [
    "authorization"
  ],
  "properties": {
    "authorization": {
      "type": "object",
      "title": "Authorization",
      "propertyOrder": 1,
      "required": [
        "#client_id",
        "#client_secret",
        "username"
      ],
      "properties": {
        "#client_id": {
          "type": "string",
          "format": "password",
          "title": "Client ID",
          "description": "Your Sage Intacct application Client ID",
          "minLength": 1,
          "propertyOrder": 1
        },
        "#client_secret": {
          "type": "string",
          "format": "password",
          "title": "Client Secret",
          "description": "Your Sage Intacct application Client Secret",
          "minLength": 1,
          "propertyOrder": 2
        },
        "username": {
          "type": "string",
          "title": "Username",
          "description": "User to log in as, in format userId@companyId",
          "minLength": 1,
          "propertyOrder": 3
        },
        "entity": {
          "type": "string",
          "title": "Entity",
          "format": "select",
          "enum": [],
          "options": {
            "async": {
              "label": "Load entities",
              "action": "list_entities"
            }
          },
          "description": "Specifies the entity for the request. If not provided, the default entity for the access token is used.",
          "propertyOrder": 4
        }
      }
    }
  }
}
